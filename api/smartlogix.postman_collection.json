{
  "info": {
    "name": "SmartLogix API - Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección Postman con ejemplos para BFF y microservicios (local)."
  },
  "item": [
    {
      "name": "BFF - Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "http://localhost:4000/health", "host": ["http://localhost:4000"], "path": ["health"] }
      }
    },
    {
      "name": "Inventory - List products (BFF)",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:4000/api/inventory/products", "host": ["http://localhost:4000"], "path": ["api","inventory","products"] }
      }
    },
    {
      "name": "Inventory - Create product (BFF)",
      "request": {
        "method": "POST",
        "header": [{"key":"Content-Type","value":"application/json"}],
        "body": {"mode":"raw","raw":"{\n  \"name\": \"Caja\",\n  \"price\": 1500\n}"},
        "url": { "raw": "http://localhost:4000/api/inventory/products", "host": ["http://localhost:4000"], "path": ["api","inventory","products"] }
      }
    },
    {
      "name": "Orders - Create order (BFF)",
      "request": {
        "method": "POST",
        "header": [{"key":"Content-Type","value":"application/json"}],
        "body": {"mode":"raw","raw":"{\n  \"customerId\": \"CUST-1\",\n  \"items\": [{ \"productId\": \"P-1\", \"quantity\": 2, \"unitPrice\": 1000 }]\n}"},
        "url": { "raw": "http://localhost:4000/api/orders", "host": ["http://localhost:4000"], "path": ["api","orders"] }
      }
    },
    {
      "name": "Shipping - Create shipment (BFF)",
      "request": {
        "method": "POST",
        "header": [{"key":"Content-Type","value":"application/json"}],
        "body": {"mode":"raw","raw":"{\n  \"orderId\": \"ORD-1\",\n  \"destinationAddress\": \"Calle 123\"\n}"},
        "url": { "raw": "http://localhost:4000/api/shipping", "host": ["http://localhost:4000"], "path": ["api","shipping"] }
      }
    },
    {
      "name": "Payment - Create intent (BFF)",
      "request": {
        "method": "POST",
        "header": [{"key":"Content-Type","value":"application/json"}],
        "body": {"mode":"raw","raw":"{\n  \"amount\": 5000,\n  \"currency\": \"CLP\",\n  \"orderId\": \"ORD-1\"\n}"},
        "url": { "raw": "http://localhost:4000/api/payment/create-intent", "host": ["http://localhost:4000"], "path": ["api","payment","create-intent"] }
      }
    }
  ]
}
